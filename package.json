{
  "name": "dofus-codex",
  "version": "0.1.63",
  "description": "DofusCodex — Le guide nouvelle génération pour Dofus 3 : donjons animés, stuffinator, quêtes et almanax.",
  "author": "DofusCodex",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "electronmon": {
    "patterns": [
      "electron/**",
      "!src/**",
      "!dist/**",
      "!release/**",
      "!docs/**",
      "!scripts/**"
    ]
  },
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electronmon .",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "dist": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "release": "vite build && electron-builder --publish always",
    "release:mac": "vite build && electron-builder --mac --publish always",
    "release:win": "vite build && electron-builder --win --publish always",
    "ship": "node scripts/release.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.dofuscodex.app",
    "productName": "DofusCodex",
    "beforePack": "build/beforePack.cjs",
    "afterPack": "build/afterPack.cjs",
    "protocols": [
      {
        "name": "DofusCodex",
        "schemes": [
          "dofuscodex"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Frensh-Developpeur",
        "repo": "DofusCodex-releases",
        "releaseType": "draft"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/macro-helper/win",
        "to": "macro-helper",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
